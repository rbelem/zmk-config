#undef LEADER
#define LEADER(name, leader_bindings, leader_sequence) \
  leader_sequence_ ## name { \
    bindings = <leader_bindings>; \
    sequence = <leader_sequence>; \
  };

LEADER(krunner, &kp LA(SPACE), SPACE)

LEADER(l_ctrlaltdel, &kp LC(LA(DEL)), Q)
LEADER(l_symbol, &sl SYMBOL, F)
LEADER(l_symbol_mirror, &sl SYMBOL_MIRROR, D)
LEADER(l_term_new, &kp LC(LA(T)), T T)
LEADER(l_term_tab, &kp LC(LS(T)), T G)

LEADER(r_ctrlaltdel, &kp LC(LA(DEL)), P)
LEADER(r_symbol, &sl SYMBOL, J)
LEADER(r_symbol_mirror, &sl SYMBOL_MIRROR, K)
LEADER(r_term_new, &kp LC(LA(T)), Y Y)
LEADER(r_term_tab, &kp LC(LS(T)), Y H)

// F-keys — left hand (V prefix, all left-hand keys)
LEADER(l_f1, &kp F1, V Q)
LEADER(l_f2, &kp F2, V W)
LEADER(l_f3, &kp F3, V E)
LEADER(l_f4, &kp F4, V R)
LEADER(l_f5, &kp F5, V T)
LEADER(l_f6, &kp F6, V A)
LEADER(l_f7, &kp F7, V S)
LEADER(l_f8, &kp F8, V D)
LEADER(l_f9, &kp F9, V F)
LEADER(l_f10, &kp F10, V G)
LEADER(l_f11, &kp F11, V Z)
LEADER(l_f12, &kp F12, V X)

// F-keys — right hand (M prefix)
LEADER(r_f1, &kp F1, M Y)
LEADER(r_f2, &kp F2, M U)
LEADER(r_f3, &kp F3, M I)
LEADER(r_f4, &kp F4, M O)
LEADER(r_f5, &kp F5, M P)
LEADER(r_f6, &kp F6, M H)
LEADER(r_f7, &kp F7, M J)
LEADER(r_f8, &kp F8, M K)
LEADER(r_f9, &kp F9, M L)
LEADER(r_f10, &kp F10, M BR_TILDE)
LEADER(r_f11, &kp F11, M N)
LEADER(r_f12, &kp F12, M M)

// Alt+F4
LEADER(l_alt_f4, &kp LA(F4), A R)
LEADER(r_alt_f4, &kp LA(F4), DOT O)

// Accented chars — left hand
LEADER(l_br_a_acute, &compose_acute A, A A)
LEADER(l_br_a_grave, &compose_grave A, A G)
LEADER(l_br_a_tilde, &compose_tilde A, A T)
LEADER(l_br_a_circ,  &compose_circ A,  A C)
LEADER(l_br_e_acute, &compose_acute E, E E)
LEADER(l_br_e_circ,  &compose_circ E,  E C)
LEADER(l_br_i_acute, &compose_acute I, Z Z)
LEADER(l_br_o_acute, &compose_acute O, X X)
LEADER(l_br_o_circ,  &compose_circ O,  X V)
LEADER(l_br_o_tilde, &compose_tilde O, X B)
LEADER(l_br_u_acute, &compose_acute U, B B)
LEADER(l_br_cedil,   &compose_cedil,   C C)

// Accented chars — right hand
LEADER(r_br_a_acute, &compose_acute A, COMMA COMMA)
LEADER(r_br_a_grave, &compose_grave A, COMMA DOT)
LEADER(r_br_a_tilde, &compose_tilde A, COMMA BR_TILDE)
LEADER(r_br_a_circ,  &compose_circ A,  COMMA N)
LEADER(r_br_e_acute, &compose_acute E, DOT DOT)
LEADER(r_br_e_circ,  &compose_circ E,  DOT N)
LEADER(r_br_i_acute, &compose_acute I, I I)
LEADER(r_br_o_acute, &compose_acute O, O O)
LEADER(r_br_o_circ,  &compose_circ O,  O C)
LEADER(r_br_o_tilde, &compose_tilde O, O T)
LEADER(r_br_u_acute, &compose_acute U, U U)
LEADER(r_br_cedil,   &compose_cedil,   BR_SEMI BR_SEMI)
