#undef LEADER
#define LEADER(name, leader_bindings, leader_sequence) \
  leader_sequence_ ## name { \
    bindings = <leader_bindings>; \
    sequence = <leader_sequence>; \
  };

LEADER(krunner, &kp LA(SPACE), SPACE)

// Positional mirrors (via qwerty_mirror):
// Qâ†”P  Wâ†”O  Eâ†”I  Râ†”U  Tâ†”Y
// Aâ†”~  Sâ†”L  Dâ†”K  Fâ†”J  Gâ†”H
// Zâ†”;  Xâ†”.  Câ†”,  Vâ†”M  Bâ†”N

// Basic sequences â€” left
LEADER(l_ctrlaltdel, &kp LC(LA(DEL)), Q)
LEADER(l_symbol, &sl SYMBOL, F)
LEADER(l_symbol_mirror, &sl SYMBOL_MIRROR, D)
LEADER(l_term_new, &kp LC(LA(T)), T T)
LEADER(l_term_tab, &kp LC(LS(T)), T G)

// Basic sequences â€” right (positional mirrors)
LEADER(r_ctrlaltdel, &kp LC(LA(DEL)), P)  // Qâ†”P
LEADER(r_symbol, &sl SYMBOL, J)            // Fâ†”J
LEADER(r_symbol_mirror, &sl SYMBOL_MIRROR, K) // Dâ†”K
LEADER(r_term_new, &kp LC(LA(T)), Y Y)     // Tâ†”Y
LEADER(r_term_tab, &kp LC(LS(T)), Y H)     // Tâ†”Y, Gâ†”H

// F-keys â€” left (V prefix, Vâ†”M)
LEADER(l_f1, &kp F1, V Q)
LEADER(l_f2, &kp F2, V W)
LEADER(l_f3, &kp F3, V E)
LEADER(l_f4, &kp F4, V R)
LEADER(l_f5, &kp F5, V T)
LEADER(l_f6, &kp F6, V A)
LEADER(l_f7, &kp F7, V S)
LEADER(l_f8, &kp F8, V D)
LEADER(l_f9, &kp F9, V F)
LEADER(l_f10, &kp F10, V G)
LEADER(l_f11, &kp F11, V Z)
LEADER(l_f12, &kp F12, V X)

// F-keys â€” right (M prefix, positional mirrors)
LEADER(r_f1, &kp F1, M P)           // Vâ†”M, Qâ†”P
LEADER(r_f2, &kp F2, M O)           // Vâ†”M, Wâ†”O
LEADER(r_f3, &kp F3, M I)           // Vâ†”M, Eâ†”I
LEADER(r_f4, &kp F4, M U)           // Vâ†”M, Râ†”U
LEADER(r_f5, &kp F5, M Y)           // Vâ†”M, Tâ†”Y
LEADER(r_f6, &kp F6, M BR_TILDE)    // Vâ†”M, Aâ†”~
LEADER(r_f7, &kp F7, M L)           // Vâ†”M, Sâ†”L
LEADER(r_f8, &kp F8, M K)           // Vâ†”M, Dâ†”K
LEADER(r_f9, &kp F9, M J)           // Vâ†”M, Fâ†”J
LEADER(r_f10, &kp F10, M H)         // Vâ†”M, Gâ†”H
LEADER(r_f11, &kp F11, M BR_SEMI)   // Vâ†”M, Zâ†”;
LEADER(r_f12, &kp F12, M DOT)       // Vâ†”M, Xâ†”.

// Alt+F4
LEADER(l_alt_f4, &kp LA(F4), A R)
LEADER(r_alt_f4, &kp LA(F4), BR_TILDE U)  // Aâ†”~, Râ†”U

// Accented chars â€” left hand
LEADER(l_br_a_acute, &compose_acute A, A A)
LEADER(l_br_a_grave, &compose_grave A, A G)
LEADER(l_br_a_tilde, &compose_tilde A, A T)
LEADER(l_br_a_circ,  &compose_circ A,  A C)
LEADER(l_br_e_acute, &compose_acute E, E E)
LEADER(l_br_e_circ,  &compose_circ E,  E C)
LEADER(l_br_i_acute, &compose_acute I, S S)  // I-sub: Sâ†”L
LEADER(l_br_o_acute, &compose_acute O, W W)  // O-sub: Wâ†”O
LEADER(l_br_o_circ,  &compose_circ O,  W C)
LEADER(l_br_o_tilde, &compose_tilde O, W T)
LEADER(l_br_u_acute, &compose_acute U, R R)  // U-sub: Râ†”U
LEADER(l_br_cedil,   &compose_cedil,   C C)

// Accented chars â€” right hand (positional mirrors of left)
LEADER(r_br_a_acute, &compose_acute A, BR_TILDE BR_TILDE)  // Aâ†”~
LEADER(r_br_a_grave, &compose_grave A, BR_TILDE H)         // Aâ†”~, Gâ†”H
LEADER(r_br_a_tilde, &compose_tilde A, BR_TILDE Y)         // Aâ†”~, Tâ†”Y
LEADER(r_br_a_circ,  &compose_circ A,  BR_TILDE COMMA)     // Aâ†”~, Câ†”,
LEADER(r_br_e_acute, &compose_acute E, I I)                // Eâ†”I
LEADER(r_br_e_circ,  &compose_circ E,  I COMMA)            // Eâ†”I, Câ†”,
LEADER(r_br_i_acute, &compose_acute I, L L)                // Sâ†”L
LEADER(r_br_o_acute, &compose_acute O, O O)                // Wâ†”O
LEADER(r_br_o_circ,  &compose_circ O,  O COMMA)            // Wâ†”O, Câ†”,
LEADER(r_br_o_tilde, &compose_tilde O, O Y)                // Wâ†”O, Tâ†”Y
LEADER(r_br_u_acute, &compose_acute U, U U)                // Râ†”U
LEADER(r_br_cedil,   &compose_cedil,   COMMA COMMA)        // Câ†”,
